# Auto-activate conda env for this repo via direnv
# Requires: direnv installed + shell hook in ~/.zshrc

if ! command -v conda >/dev/null 2>&1; then
  echo "conda not found in PATH"
  exit 1
fi

# Ensure conda shell functions are loaded in non-interactive direnv context
CONDA_BASE="$(conda info --base 2>/dev/null)"
if [ -n "$CONDA_BASE" ] && [ -f "$CONDA_BASE/etc/profile.d/conda.sh" ]; then
  source "$CONDA_BASE/etc/profile.d/conda.sh"
fi

conda activate datascience >/dev/null 2>&1 || {
  echo "Failed to activate conda env: datascience"
  exit 1
}
